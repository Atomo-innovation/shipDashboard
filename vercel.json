{
  "installCommand": "echo 'skip-install'",
  "buildCommand": "rm -rf dist && mkdir dist && cp -R public/. dist/",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/twin", "destination": "/three_realistic.html" }
  ],
  "cleanUrls": true,
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
